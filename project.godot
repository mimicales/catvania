; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="YarnBeast"
config/description="Tes voisins ont presque tous disparu et c'est à toi de les retrouver! Un metroidvania cosy en 2D où chaque zone cache des compagnons à retrouver, des secrets à percer et des chemins à débloquer grâce à de nouvelles capacités. Réussiras-tu à sauver ton village?"
run/main_scene="uid://bp60xm6xlg4c7"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="uid://cxkur5kn7p8ju"

[autoload]

SceneManager="*res://00_global/scene_manager/scene_manager.tscn"
SaveManager="*res://00_global/save_manager.gd"
Messages="*res://00_global/messages.gd"
PlayerHud="*res://00_global/player_hud/player_hud.tscn"
Audio="*res://00_global/audio/audio.tscn"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="canvas_items"

[global_group]

Player=""
Camera=""
tilemap=""

[gui]

theme/custom_font="uid://dqt0kd8vohrfq"

